{
  "name": "live-tab-mirror",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "auth:code": "node scripts/generate-supabase-login-code.mjs",
    "build": "npm run build --workspaces --if-present",
    "dev:mobile": "npm run dev -w @live-tab-mirror/mobile",
    "test": "vitest run",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "26.0.1",
    "@vitejs/plugin-react": "6.0.3",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vitest": "4.1.9"
  }
}
